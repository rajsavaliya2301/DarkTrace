# =============================================================================
# DarkTrace - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
# DO NOT commit the .env file to version control.

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=DarkTrace
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=info
LOG_FORMAT=json
API_PREFIX=/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Security / JWT ──────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-strong-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://darktrace:darktrace_pass@mongodb:27017/darktrace?authSource=admin
MONGODB_DATABASE=darktrace
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=10
MONGO_INITDB_ROOT_USERNAME=darktrace
MONGO_INITDB_ROOT_PASSWORD=darktrace_pass
MONGO_INITDB_DATABASE=darktrace

# ─── Elasticsearch ───────────────────────────────────────────────────────────
ELASTICSEARCH_HOSTS=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=darktrace_es_pass
ELASTICSEARCH_VERIFY_CERTS=false

# ─── Neo4j ───────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=darktrace_neo4j_pass
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_AUTH=neo4j/darktrace_neo4j_pass

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URI=redis://:darktrace_redis_pass@redis:6379/0
REDIS_PASSWORD=darktrace_redis_pass
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://darktrace:darktrace_rabbit_pass@rabbitmq:5672/
RABBITMQ_DEFAULT_USER=darktrace
RABBITMQ_DEFAULT_PASS=darktrace_rabbit_pass
RABBITMQ_DEFAULT_VHOST=/

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_USER=100
RATE_LIMIT_PER_IP=1000
RATE_LIMIT_WINDOW_SECONDS=60

# ─── Crawler ─────────────────────────────────────────────────────────────────
CRAWL_DELAY=5.0
CONCURRENT_REQUESTS=8
PROXY_REFRESH_INTERVAL=600
MAX_RETRIES=3
CRAWL_TIMEOUT=60

# ─── Tor Proxy ───────────────────────────────────────────────────────────────
TOR_PROXY_HOST=tor-proxy
TOR_PROXY_PORT=9050

# ─── I2P Proxy ───────────────────────────────────────────────────────────────
I2P_PROXY_HOST=i2p-proxy
I2P_PROXY_PORT=4444

# ─── NLP ─────────────────────────────────────────────────────────────────────
SPACY_MODEL_EN=en_core_web_sm
TRANSLATION_CACHE_TTL=2592000

# ─── Threat Scoring ──────────────────────────────────────────────────────────
THREAT_SCORE_WEIGHTS={"classification":0.30,"high_value_targets":0.20,"actor_reputation":0.15,"freshness":0.10,"sentiment":0.10,"keyword_matches":0.10,"site_reputation":0.05}

# ─── Report ──────────────────────────────────────────────────────────────────
REPORT_EXPIRY_HOURS=1
REPORT_STORAGE_PATH=/tmp/darktrace/reports

# ─── SIEM ────────────────────────────────────────────────────────────────────
SIEM_SYSLOG_HOST=
SIEM_SYSLOG_PORT=514

# ─── Default Admin ───────────────────────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@darktrace.com
DEFAULT_ADMIN_PASSWORD=changeme_admin_password

# ─── External Threat Intelligence API Keys ───────────────────────────────────
# Get a free VirusTotal API key: https://www.virustotal.com/gui/join-us
# VIRUSTOTAL_API_KEY=
# Get a free Shodan API key: https://account.shodan.io/register
# SHODAN_API_KEY=
# Get a free AlienVault OTX API key: https://otx.alienvault.com/api
# OTX_API_KEY=

# ─── Docker Image Tag ────────────────────────────────────────────────────────
DOCKER_REGISTRY=ghcr.io
DOCKER_NAMESPACE=darktrace
IMAGE_TAG=latest
